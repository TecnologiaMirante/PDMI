  "measures": [
    {
      "name": "Total Negociações",
      "table": "_Medidas",
      "expression": "COUNTROWS('fNegócios')",
      "formatString": "#,##0"
    },
    {
      "name": "Valor Carteira",
      "table": "_Medidas",
      "expression": "SUM('fNegócios'[valor_total])",
      "formatString": "\"R$\" #,##0"
    },
    {
      "name": "Negocios Ganhos Qtd",
      "table": "_Medidas",
      "expression": "CALCULATE(COUNTROWS('fNegócios'), 'fNegócios'[Status] = \"Ganho\")",
      "formatString": "#,##0"
    },
    {
      "name": "Valor Ganho",
      "table": "_Medidas",
      "expression": "CALCULATE(SUM('fNegócios'[valor_total]), 'fNegócios'[Status] = \"Ganho\")",
      "formatString": "\"R$\" #,##0"
    },
    {
      "name": "Negocios Perdidos Qtd",
      "table": "_Medidas",
      "expression": "CALCULATE(COUNTROWS('fNegócios'), 'fNegócios'[Status] = \"Perdido\")",
      "formatString": "#,##0"
    },
    {
      "name": "Valor Perdido",
      "table": "_Medidas",
      "expression": "CALCULATE(SUM('fNegócios'[valor_total]), 'fNegócios'[Status] = \"Perdido\")",
      "formatString": "\"R$\" #,##0"
    },
    {
      "name": "Em Aberto Qtd",
      "table": "_Medidas",
      "expression": "CALCULATE(COUNTROWS('fNegócios'), 'fNegócios'[Status] = \"Em Aberto\")",
      "formatString": "#,##0"
    },
    {
      "name": "Valor Em Aberto",
      "table": "_Medidas",
      "expression": "CALCULATE(SUM('fNegócios'[valor_total]), 'fNegócios'[Status] = \"Em Aberto\")",
      "formatString": "\"R$\" #,##0"
    },
    {
      "name": "Taxa Conversao",
      "table": "_Medidas",
      "expression": "DIVIDE([Negocios Ganhos Qtd], [Total Negociações], 0)",
      "formatString": "0.0%"
    },
    {
      "name": "Ticket Medio",
      "table": "_Medidas",
      "expression": "DIVIDE([Valor Carteira], [Total Negociações], 0)",
      "formatString": "\"R$\" #,##0"
    },
    {
      "name": "Ticket Medio Ganhos",
      "table": "_Medidas",
      "expression": "DIVIDE([Valor Ganho], [Negocios Ganhos Qtd], 0)",
      "formatString": "\"R$\" #,##0"
    },
    {
      "name": "Abertas Mais 90 Dias",
      "table": "_Medidas",
      "expression": "CALCULATE(",
      "formatString": "#,##0"
    },
    {
      "name": "Duracao Media Dias",
      "table": "_Medidas",
      "expression": "AVERAGEX('fNegócios', 'fNegócios'[Duracao Dias])",
      "formatString": "#,##0"
    },
    {
      "name": "Duracao Media Ganhos",
      "table": "_Medidas",
      "expression": "CALCULATE(",
      "formatString": "#,##0"
    },
    {
      "name": "Pct Status Ganho",
      "table": "_Medidas",
      "expression": "DIVIDE([Negocios Ganhos Qtd], [Total Negociações], 0) * 100",
      "formatString": "0.0"
    },
    {
      "name": "Pct Status Perdido",
      "table": "_Medidas",
      "expression": "DIVIDE([Negocios Perdidos Qtd], [Total Negociações], 0) * 100",
      "formatString": "0.0"
    },
    {
      "name": "Pct Status Em Aberto",
      "table": "_Medidas",
      "expression": "DIVIDE([Em Aberto Qtd], [Total Negociações], 0) * 100",
      "formatString": "0.0"
    },
